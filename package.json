{
  "name": "diamond-focus",
  "description": "A timer for diamond focus built building stronger brains under pressure.",
  "author": "Gabe Cornejo",
  "version": "0.6.3",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gccornejo441/Diamond-Focus"
  },
  "type": "module",
  "keywords": [
    "react",
    "diamond",
    "focus",
    "timer",
    "pomodoro",
    "typescript",
    "vite",
    "eslint",
    "prettier",
    "react-tooltip",
    "react-contexify",
    "date-fns",
    "dnd-kit",
    "dnd-kit-sortable"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --fix --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx,css,scss,md}'",
    "preview": "vite preview",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "brace": "0.11.1",
    "date-fns": "4.1.0",
    "firebase": "12.12.1",
    "highlight.js": "11.11.1",
    "peerjs": "1.5.5",
    "react": "19.2.5",
    "react-contexify": "6.0.0",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.14.2",
    "react-toastify": "11.1.0",
    "react-tooltip": "6.0.0",
    "reactjs-popup": "2.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-svgr": "5.2.0"
  }
}
